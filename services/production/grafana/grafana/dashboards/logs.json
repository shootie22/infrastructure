          "maxLines": 100,
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent SSH Attempts",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "json",
            "keepTime": true,
            "replace": true,
            "source": "Line"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Line": true,
              "labels": true
            },
            "indexByName": {
              "Time": 0,
              "Server": 1,
              "IP": 2,
              "Username": 3,
              "Status": 4
            },
            "renameByName": {
              "Time": "Timestamp"
            }
          }
        }
      ],
      "type": "table"
