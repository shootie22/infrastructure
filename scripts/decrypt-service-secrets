#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

umask 077

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
TARGET_DIR="${1:-.}"

if [[ "$TARGET_DIR" != /* ]]; then
  TARGET_DIR="$PWD/$TARGET_DIR"
fi

if [[ ! -d "$TARGET_DIR" ]]; then
  echo "error: directory not found: $TARGET_DIR" >&2
  exit 1
fi

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "error: missing dependency: $1" >&2
    exit 1
  }
}

require_cmd sops

if [[ -z "${SOPS_AGE_KEY:-}" ]]; then
  if [[ -n "${SOPS_AGE_KEY_FILE:-}" && -f "${SOPS_AGE_KEY_FILE}" ]]; then
    export SOPS_AGE_KEY="$(cat "${SOPS_AGE_KEY_FILE}")"
  else
    echo "error: SOPS_AGE_KEY is not set (or set SOPS_AGE_KEY_FILE)" >&2
    exit 1
  fi
fi

note() {
  echo "==> $*" >&2
}

cd "$TARGET_DIR"

if [[ -f .env ]]; then
  note "Decrypting .env -> runtime.env"
  sops --decrypt .env > runtime.env
fi

if [[ -f .rathole.toml ]]; then
  note "Decrypting .rathole.toml -> rathole.toml"
  sops --decrypt .rathole.toml > rathole.toml
fi
