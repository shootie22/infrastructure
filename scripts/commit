#!/usr/bin/env bash
set -euo pipefail
IFS=$'\n\t'

msg="${*:-}"
if [[ -z "$msg" ]]; then
  echo "usage: scripts/commit.sh \"commit message\"" >&2
  exit 1
fi

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd -P)"
cd "$ROOT_DIR"

if [[ ! -x "$ROOT_DIR/scripts/encrypt-runtime-env" ]]; then
  echo "error: missing scripts/encrypt-runtime-env (or not executable)" >&2
  exit 1
fi

"$ROOT_DIR/scripts/encrypt-runtime-env"

git add -A

if git diff --cached --quiet; then
  echo "error: no changes to commit" >&2
  exit 1
fi

git commit -m "$msg"

remote="${COMMIT_REMOTE:-origin}"
branch="${COMMIT_BRANCH:-main}"

git push "$remote" "$branch"
